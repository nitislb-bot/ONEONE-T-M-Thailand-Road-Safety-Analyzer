{
  "entities": {
    "SafetyAnalysis": {
      "title": "Safety Analysis",
      "description": "A road safety analysis report for a specific area.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "number" },
        "province": { "type": "string" },
        "district": { "type": "string" },
        "workOrderName": { "type": "string" },
        "createdBy": { "type": "string" },
        "lastUpdatedBy": { "type": "string" },
        "overallRisk": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "summary": { "type": "string" },
        "historicalDataSummary": { "type": "string" },
        "blackSpots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "locationName": { "type": "string" },
              "latitude": { "type": "number" },
              "longitude": { "type": "number" },
              "riskLevel": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
              "accidentCount": { "type": "integer" },
              "injuryCount": { "type": "integer" },
              "fatalityCount": { "type": "integer" },
              "riskFactors": { "type": "array", "items": { "type": "string" } },
              "recommendation": { "type": "string" },
              "confirmations": { "type": "number" },
              "comments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "timestamp": { "type": "number" }
                  }
                }
              }
            }
          }
        },
        "recentAccidents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "locationName": { "type": "string" },
              "latitude": { "type": "number" },
              "longitude": { "type": "number" },
              "type": { "type": "string" },
              "severity": { "type": "string", "enum": ["Minor", "Major", "Fatal"] },
              "timestamp": { "type": "string" },
              "description": { "type": "string" },
              "confirmations": { "type": "number" },
              "comments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "timestamp": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["id", "timestamp", "province", "district", "overallRisk", "summary", "blackSpots", "recentAccidents"]
    }
  },
  "firestore": {
    "/analyses/{analysisId}": {
      "schema": "SafetyAnalysis",
      "description": "Collection of all shared safety analyses."
    }
  }
}
